package dbosui

import (
	"github.com/laenen-partners/dsx"
	"github.com/laenen-partners/dsx/ds"
	"github.com/laenen-partners/dsx/layouts"
	"github.com/laenen-partners/dsx/showcase"
)

// ShowcasePage renders the admin page wrapped in the DSX showcase chrome
// (identity switcher, theme dropdown, etc).
templ ShowcasePage() {
	@showcase.Page("DBOS Admin") {
		@workflowsContent()
	}
}

// AdminPage renders a standalone admin page with full HTML layout.
// Used by the embeddable Handler().
templ AdminPage() {
	{{ wxctx := dsx.FromContext(ctx) }}
	@layouts.Base(layouts.BaseProps{
		Title:     "DBOS Admin",
		CSRFToken: wxctx.CSRFToken,
		Theme:     wxctx.Theme,
		Head:      adminHead(),
	}) {
		<div class="navbar bg-base-200 px-4 shadow-sm">
			<div class="flex-1">
				<span class="text-lg font-bold">DBOS Admin</span>
			</div>
		</div>
		<div class="p-6 max-w-7xl mx-auto">
			@workflowsContent()
		</div>
	}
}

templ adminHead() {
	{{ wxctx := dsx.FromContext(ctx) }}
	<link rel="stylesheet" href={ wxctx.APIPath("/assets/css/output.css") }/>
	<script type="module" src={ wxctx.APIPath("/assets/js/datastar.js") }></script>
}

templ workflowsContent() {
	{{ wxctx := dsx.FromContext(ctx) }}
	{{ signals := ds.NewSignals("wf_filter", filterSignals{}) }}
	<div class="space-y-6" data-signals={ signals.DataSignals }>
		// Stats
		<div
			id="wf-stats"
			{ ds.Init(ds.GetOnce(wxctx.APIPath("/workflows/stats")))... }
		>
			<div class="flex gap-4">
				<div class="skeleton h-20 w-full"></div>
				<div class="skeleton h-20 w-full"></div>
				<div class="skeleton h-20 w-full"></div>
				<div class="skeleton h-20 w-full"></div>
			</div>
		</div>
		// Filters
		<div class="flex items-center gap-3 flex-wrap">
			<select
				class="select select-bordered select-sm"
				{ ds.Bind("wf_filter", "status")... }
				{ ds.On("change", signals.Set("page", "0") + "; " + ds.Get(wxctx.APIPath("/workflows/list")))... }
			>
				<option value="">All Statuses</option>
				<option value="PENDING">Pending</option>
				<option value="ENQUEUED">Enqueued</option>
				<option value="SUCCESS">Success</option>
				<option value="ERROR">Error</option>
				<option value="CANCELLED">Cancelled</option>
			</select>
			<input
				type="text"
				class="input input-bordered input-sm w-64"
				placeholder="Search by name..."
				{ ds.Bind("wf_filter", "name")... }
				{ ds.On("input.debounce_300ms", signals.Set("page", "0") + "; " + ds.Get(wxctx.APIPath("/workflows/list")))... }
			/>
			<div class="flex-1"></div>
			<button
				class="btn btn-ghost btn-sm"
				{ ds.OnClick(ds.Get(wxctx.APIPath("/workflows/list")) + "; " + ds.Get(wxctx.APIPath("/workflows/stats")))... }
			>
				Refresh
			</button>
		</div>
		// Table
		<div class="overflow-x-auto rounded-lg border border-base-300">
			<table class="table table-zebra">
				<thead>
					<tr class="bg-base-200">
						<th>ID</th>
						<th>Name</th>
						<th>Status</th>
						<th>User</th>
						<th>Created</th>
						<th>Attempts</th>
						<th class="w-20"></th>
					</tr>
				</thead>
				<tbody
					id="wf-table-body"
					{ ds.Init(ds.Get(wxctx.APIPath("/workflows/list")))... }
				>
					<tr>
						<td colspan="7" class="text-center py-8 text-base-content/50">
							<span class="loading loading-spinner"></span>
						</td>
					</tr>
				</tbody>
			</table>
		</div>
		// Pagination
		<div id="wf-pagination" class="flex justify-center"></div>
	</div>
}
